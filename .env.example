# ============================================================
# HiveDeploy 环境变量配置
# ============================================================
# 复制为 .env 后填入实际值
# ============================================================

# Panel 密钥（务必修改，用于 session 加密）
SECRET_KEY=change_this_to_a_long_random_string_in_production

# 管理员初始账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 服务器公网 IP 或域名（用于 bot 实例对外访问地址生成）
# 国内服务器填 IP 即可
PLATFORM_HOST=your.server.ip.or.domain

# ═══ simple 模式（docker-compose.simple.yml） ═══
# Panel 对外端口（非 80/443，免备案）
PANEL_PORT=9200

# CORS 允许的来源，逗号分隔，"*" 表示允许所有
CORS_ALLOW_ORIGINS=*

# ═══ 原版模式（docker-compose.yml） ═══
# Panel 对外端口（默认 80，需有域名+备案）
# PANEL_PORT=80

# Traefik 仪表盘端口
# TRAEFIK_DASHBOARD_PORT=8080

# Bot 实例端口基数（每用户 10 个端口）
INSTANCE_PORT_BASE=20000